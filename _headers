# Cache & security headers for Cipritravel Tours (Cloudflare Pages)

# HTML — no cache (sempre fresco)
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# JSON data — SEM cache no browser, cache mínimo no CDN.
# O JS já faz cache-busting com ?v=timestamp, mas isto garante que mesmo
# clientes antigos (sem o cache-bust) ou crawlers sempre veem conteúdo fresco.
/data/*.json
  Cache-Control: public, max-age=0, must-revalidate, s-maxage=10

# Imagens, fontes e JS — cache longo
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Admin — no index
/admin/*
  X-Robots-Tag: noindex

# Security headers globais
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
